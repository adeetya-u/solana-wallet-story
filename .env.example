# Server-only mainnet HTTPS RPC (Helius / QuickNode / etc.). Required for reliable prod:
# browser calls /api/solana-rpc and this URL is used server-side (key stays off the client).
SOLANA_RPC_URL=

# Optional: skip the proxy and call this URL directly from the browser (exposes provider URL in DevTools).
NEXT_PUBLIC_SOLANA_RPC_URL=

# Canonical site URL — used when request origin header is absent (cron, SSR).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Solana pubkey to receive SOL tips via /api/actions/tip (Blink / Actions).
TIP_RECIPIENT=
